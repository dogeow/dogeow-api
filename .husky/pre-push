cd "$(dirname "$0")/.."

# 获取将要推送的修改文件
changed_files=$(git diff --name-only @{upstream}..HEAD 2>/dev/null || git diff --name-only HEAD~1..HEAD)

# 检查关键文件是否修改（这些文件改动需要跑全量测试）
critical_files="composer.json|phpunit.xml|\.env\.example|config/"
if echo "$changed_files" | grep -qE "$critical_files"; then
    echo "⚠ Critical files changed, running full test suite..."
    vendor/bin/phpunit --no-coverage
    exit $?
fi

# 检查是否有 PHP 文件修改
if ! echo "$changed_files" | grep -q '\.php$'; then
    echo "✓ No PHP files changed, skipping tests"
    exit 0
fi

# 查找修改的测试文件
test_files=$(echo "$changed_files" | grep '^tests/.*\.php$' | tr '\n' ' ' || true)

# 查找修改的源文件对应的测试文件
app_files=$(echo "$changed_files" | grep '^app/.*\.php$' || true)
if [ -n "$app_files" ]; then
    for file in $app_files; do
        base=$(basename "$file" .php)
        test_candidates="tests/Unit/**/${base}Test.php tests/Feature/**/${base}Test.php"
        for pattern in $test_candidates; do
            found=$(find tests -path "$pattern" 2>/dev/null)
            if [ -n "$found" ]; then
                test_files="$test_files $found"
            fi
        done
    done
fi

# 如果找到了相关测试，只运行这些；否则运行全量
if [ -n "$test_files" ]; then
    echo "→ Running tests for changed files..."
    vendor/bin/phpunit --no-coverage $test_files
else
    echo "⚠ No specific tests found, running full suite..."
    vendor/bin/phpunit --no-coverage
fi
